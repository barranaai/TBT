# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
# NOTE: .next is committed (minus cache) so GoDaddy can SERVE a prebuilt app
# without building on the server (its sandbox can't run the Next build).
/.next/cache/
/out/

# production
/build

# local uploaded photos (dev fallback for the inquiry form)
/.uploads

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# local agent / editor config
.claude

# typescript
*.tsbuildinfo
next-env.d.ts

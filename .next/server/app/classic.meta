{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/classic/layout,_N_T_/classic/page,_N_T_/classic"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/classic/__PAGE__",
    "/classic",
    "/_index",
    "/_head"
  ]
}